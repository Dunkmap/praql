{
  "manifest_version": 3,
  "name": "SQL Master - Learn & Practice SQL",
  "version": "1.1.0",
  "description": "A comprehensive, free SQL learning extension with interactive playground, 200+ practice questions, Google Sheets SQL integration, and structured learning paths.",
  "permissions": ["storage", "unlimitedStorage", "tabs", "clipboardRead", "clipboardWrite", "activeTab", "scripting"],
  "host_permissions": [
    "https://docs.google.com/spreadsheets/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["sheets/sheets_content.js"],
      "css": ["sheets/sheets_panel.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sql_engine/*",
        "datasets/*",
        "lessons/*",
        "questions/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
